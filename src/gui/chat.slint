import { Button, VerticalBox, LineEdit, TextEdit, StandardListView, GroupBox, HorizontalBox, Switch } from "std-widgets.slint";

export component ChatWindow inherits Window {
    title: "nkCryptoTool Chat (v2.0.0)";
    width: 800px;
    height: 600px;

    callback connect-pressed(string, string, string); // ticket, privkey_path, pubkey_path
    callback passphrase-provided(string);
    callback send-message(string);
    callback copy-to-clipboard(string);
    callback scan-qr-pressed();
    callback scan-cancel();
    callback privacy-mode-toggled(bool);
    
    in property <[StandardListViewItem]> messages: [];
    in property <bool> connected: false;
    in property <bool> asking-passphrase: false;
    in property <bool> scanning-qr: false;
    in property <string> connection-error: "";
    in property <string> scanner-status: "";
    in property <string> privacy-warning: "";
    
    in-out property <string> input-text: "";
    in-out property <string> ticket-text: "";
    in-out property <string> privkey-path: "";
    in-out property <string> pubkey-path: "";
    in-out property <string> passphrase-input: "";
    in-out property <bool> privacy-mode: false;

    VerticalBox {
        // Privacy Mode and Warning
        HorizontalBox {
            alignment: start;
            Text {
                text: "Privacy Mode:";
                vertical-alignment: center;
            }
            Switch {
                checked <=> privacy-mode;
                toggled => { root.privacy-mode-toggled(self.checked); }
            }
            if privacy-warning != "" : Text {
                text: privacy-warning;
                color: orange;
                font-size: 10px;
                vertical-alignment: center;
            }
        }

        // Error display
        if connection-error != "" : Text {
            text: connection-error;
            color: red;
        }

        // 1. Connection Settings
        if !connected && !asking-passphrase && !scanning-qr : GroupBox {
            title: "Connection Settings";
            VerticalBox {
                HorizontalBox {
                    LineEdit {
                        placeholder-text: "Ticket (nkct1...)";
                        text <=> ticket-text;
                    }
                    Button {
                        text: "Copy";
                        clicked => { root.copy-to-clipboard(root.ticket-text); }
                    }
                    Button {
                        text: "Scan QR";
                        clicked => { root.scan-qr-pressed(); }
                    }
                }
                LineEdit {
                    placeholder-text: "Private Key Path";
                    text <=> privkey-path;
                }
                LineEdit {
                    placeholder-text: "Public Key Path (Peer)";
                    text <=> pubkey-path;
                }
                Button {
                    text: "Connect";
                    clicked => {
                        root.connection-error = "";
                        root.connect-pressed(root.ticket-text, root.privkey-path, root.pubkey-path);
                    }
                }
            }
        }
        
        // 2. Passphrase Dialog (M1)
        if asking-passphrase : GroupBox {
            title: "Passphrase Required";
            VerticalBox {
                Text {
                    text: "The private key is encrypted. Please enter the passphrase.";
                }
                Text {
                    text: "⚠️ Please turn OFF IME and use half-width characters.";
                    font-size: 10px;
                    color: orange;
                }
                LineEdit {
                    // M1/M3: password type hides input and prevents clipboard copy on most platforms
                    input-type: password;
                    placeholder-text: "Enter Passphrase";
                    text <=> passphrase-input;
                    accepted => {
                        root.passphrase-provided(root.passphrase-input);
                        root.passphrase-input = "";
                    }
                }
                Button {
                    text: "Unlock and Connect";
                    clicked => {
                        root.passphrase-provided(root.passphrase-input);
                        root.passphrase-input = "";
                    }
                }
                Button {
                    text: "Cancel";
                    clicked => {
                        root.asking-passphrase = false;
                        root.passphrase-input = "";
                    }
                }
            }
        }

        // 3. QR Scanner (M2)
        if scanning-qr : GroupBox {
            title: "QR Code Scanner";
            VerticalBox {
                Text {
                    text: "📷 Camera Active (Scanning for Ticket)";
                    color: green;
                }
                Text {
                    text: scanner-status;
                }
                // Preview would ideally be here, but for now we focus on logic
                Button {
                    text: "Cancel";
                    clicked => { root.scan-cancel(); }
                }
            }
        }
        
        // 4. Chat Messages
        if connected : StandardListView {
            model: messages;
            min-height: 200px;
        }
        
        // 5. Message Input
        if connected : VerticalBox {
            LineEdit {
                text <=> input-text;
                placeholder-text: "Type a message...";
                accepted => {
                    root.send-message(root.input-text);
                    root.input-text = "";
                }
            }
            Button {
                text: "Send";
                clicked => {
                    root.send-message(root.input-text);
                    root.input-text = "";
                }
            }
        }
    }
}
